/* privacy.wxss - 隐私政策 | 统一风格 */

page {
  background: #F5F7FA;
  min-height: 100vh;
}

.privacy-container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ═══════════════════════════════════════
   页面头部
   ═══════════════════════════════════════ */
.page-header {
  padding: 32rpx 32rpx 20rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}
.header-step {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 400;
}

/* ═══════════════════════════════════════
   条款卡片
   ═══════════════════════════════════════ */
.privacy-body {
  padding: 0 32rpx;
}

.privacy-section {
  display: flex;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.section-num {
  width: 48rpx; height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #2563EB, #3B82F6);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
}

.section-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.8;
}

/* ═══════════════════════════════════════
   底部
   ═══════════════════════════════════════ */
.privacy-footer {
  text-align: center;
  padding: 40rpx 32rpx 0;
}
.footer-line {
  width: 60rpx; height: 3rpx;
  background: #D1D5DB;
  border-radius: 2rpx;
  margin: 0 auto 16rpx;
}
.privacy-footer text {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ═══════════════════════════════════════
   动画
   ═══════════════════════════════════════ */
@keyframes fadeIn { from { opacity:0; transform:translateY(20rpx); } to { opacity:1; transform:translateY(0); } }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.fade-in { animation: fadeIn 0.4s ease forwards; }
.fade-in-up { opacity:0; animation: fadeInUp 0.4s ease forwards; }
