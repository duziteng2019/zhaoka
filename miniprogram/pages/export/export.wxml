<!--pages/export/export.wxml-->
<view class="export-container page-container">

  <!-- 页面头部 -->
  <view class="page-header fade-in">
    <view class="header-title">导出下载</view>
    <view class="header-step">完成 ✓</view>
  </view>

  <!-- 预览卡片 -->
  <view class="preview-card fade-in-up">
    <view class="preview-area">
      <image class="preview-image" src="{{previewUrl}}" mode="aspectFit"></image>
    </view>
    <view class="preview-info">
      <view class="info-item">
        <text class="info-label">照片规格</text>
        <text class="info-value">{{specName}}</text>
      </view>
      <view class="info-divider"></view>
      <view class="info-item">
        <text class="info-label">背景颜色</text>
        <text class="info-value">{{bgColorName}}</text>
      </view>
    </view>
  </view>

  <!-- 下载选项 -->
  <view class="download-section fade-in-up">
    <view class="section-label">选择下载方式</view>

    <!-- 免费 -->
    <view class="option-card option-free {{selectedOption === 'free' ? 'active' : ''}}" bindtap="selectOption" data-option="free">
      <view class="option-left">
        <view class="option-badge-free">免费</view>
        <view class="option-body">
          <text class="option-title">预览版</text>
          <text class="option-desc">含"预览版"水印，低分辨率</text>
        </view>
      </view>
      <view class="option-check {{selectedOption === 'free' ? 'checked' : ''}}">
        <view class="check-dot"></view>
      </view>
    </view>

    <!-- 付费 (突出) -->
    <view class="option-card option-hd {{selectedOption === 'hd' ? 'active' : ''}}" bindtap="selectOption" data-option="hd">
      <view class="hd-tag">推荐</view>
      <view class="option-left">
        <view class="option-icon-hd">
          <view class="css-icon hd-star"></view>
        </view>
        <view class="option-body">
          <text class="option-title">高清原图</text>
          <text class="option-desc">无水印，高分辨率，支持冲印</text>
        </view>
      </view>
      <view class="option-price-tag">¥9.9</view>
      <view class="option-check {{selectedOption === 'hd' ? 'checked' : ''}}">
        <view class="check-dot"></view>
      </view>
    </view>
  </view>

  <!-- 注意事项 -->
  <view class="notice-section fade-in">
    <view class="notice-icon">!</view>
    <view class="notice-text">
      • 免费预览版仅供预览，不可用于正式场合
      • 高清版支付后自动下载保存到相册
      • 历史记录可随时查看已购图片
    </view>
  </view>

  <!-- 底部 -->
  <view class="bottom-action">
    <button class="btn btn-ghost" bindtap="goHome">返回首页</button>
    <button class="btn btn-primary btn-large btn-block" bindtap="download" wx:if="{{selectedOption === 'hd'}}">
      立即支付 ¥9.9
    </button>
    <button class="btn btn-secondary btn-large btn-block" bindtap="download" wx:else>
      免费下载
    </button>
  </view>
</view>
