/* pages/historyDetail/historyDetail.wxss */
/* Uses CSS variables and utility classes from app.wxss */

.preview-section {
  display: flex;
  justify-content: center;
  margin: var(--space-md) 0;
}

.preview-card {
  width: 100%;
  height: 600rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.info-row {
  display: flex;
  align-items: center;
  padding: var(--space-sm) 0;
  gap: var(--space-md);
}

.info-label {
  font-size: var(--text-base);
  color: var(--text-secondary);
  min-width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: var(--text-base);
  color: var(--text-primary);
  font-weight: 500;
  flex: 1;
}

.actions-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-lg);
}
