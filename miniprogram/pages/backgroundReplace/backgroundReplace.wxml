<!--pages/backgroundReplace/backgroundReplace.wxml-->
<view class="bg-container page-container">
  <!-- 页面头部 -->
  <view class="header fade-in">
    <view class="header-title">背景颜色</view>
    <view class="header-step">第 3 步</view>
  </view>

  <!-- AI模式标签 -->
  <view class="ai-badge" wx:if="{{modeLabel}}">
    <text>{{modeLabel}}</text>
  </view>

  <!-- 分割帮助提示 -->
  <view class="mask-help" wx:if="{{showMaskHelp}}">
    <text>✅ 人像分割完成，点「遮罩」查看识别区域</text>
  </view>

  <!-- 预览区域 -->
  <view class="preview-section fade-in">
    <view class="preview-area">
      <image class="preview-image" src="{{previewUrl}}" mode="aspectFit"></image>
    </view>
  </view>

  <!-- 视图切换 -->
  <view class="view-mode-bar" wx:if="{{maskImageUrl}}">
    <view class="mode-tab {{viewMode === 'original' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="original">原始</view>
    <view class="mode-tab {{viewMode === 'mask' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="mask">遮罩</view>
    <view class="mode-tab {{viewMode === 'result' ? 'active' : ''}}" bindtap="switchViewMode" data-mode="result">结果</view>
  </view>

  <!-- 背景色选择 -->
  <view class="color-section fade-in">
    <view class="section-title">选择背景色</view>
    <view class="color-grid">
      <view class="color-item {{selectedBgColor === 'white' ? 'active' : ''}}" bindtap="selectBgColor" data-color="white">
        <view class="color-swatch white"></view>
        <view class="color-label">白色</view>
      </view>
      <view class="color-item {{selectedBgColor === 'blue' ? 'active' : ''}}" bindtap="selectBgColor" data-color="blue">
        <view class="color-swatch blue"></view>
        <view class="color-label">蓝色</view>
      </view>
      <view class="color-item {{selectedBgColor === 'red' ? 'active' : ''}}" bindtap="selectBgColor" data-color="red">
        <view class="color-swatch red"></view>
        <view class="color-label">红色</view>
      </view>
    </view>
  </view>

  <!-- 美颜调整 -->
  <view class="beauty-section fade-in">
    <view class="section-title">美颜调整</view>
    <view class="slider-item">
      <view class="slider-label">
        <text>亮度</text>
        <text class="slider-value">{{brightness}}</text>
      </view>
      <slider min="0" max="100" value="{{brightness}}" bindchange="onBrightnessChange" block-size="20" activeColor="#2563EB" backgroundColor="#E5E7EB"/>
    </view>
    <view class="slider-item">
      <view class="slider-label">
        <text>磨皮</text>
        <text class="slider-value">{{smooth}}</text>
      </view>
      <slider min="0" max="100" value="{{smooth}}" bindchange="onSmoothChange" block-size="20" activeColor="#2563EB" backgroundColor="#E5E7EB"/>
    </view>
    <view class="slider-item">
      <view class="slider-label">
        <text>饱和度</text>
        <text class="slider-value">{{saturation}}</text>
      </view>
      <slider min="-50" max="50" value="{{saturation}}" bindchange="onSaturationChange" block-size="20" activeColor="#2563EB" backgroundColor="#E5E7EB"/>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-action">
    <button class="btn btn-ghost" bindtap="goBack">上一步</button>
    <button class="btn btn-primary" bindtap="goNext">下一步</button>
  </view>
</view>
