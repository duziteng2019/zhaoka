/* profile.wxss - 个人中心 | 统一风格 */

page {
  background: #F5F7FA;
  min-height: 100vh;
}

.profile-container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ═══════════════════════════════════════
   页面头部
   ═══════════════════════════════════════ */
.page-header {
  padding: 32rpx 32rpx 20rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}

/* ═══════════════════════════════════════
   用户卡片
   ═══════════════════════════════════════ */
.user-card {
  margin: 0 32rpx 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.user-avatar {
  width: 88rpx; height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}
.user-avatar image { width: 100%; height: 100%; object-fit: cover; }

.avatar-placeholder {
  width: 100%; height: 100%;
  background: rgba(37,99,235,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-body { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.user-name { font-size: 30rpx; font-weight: 700; color: #1F2937; }
.user-desc { font-size: 22rpx; color: #9CA3AF; }

/* ═══════════════════════════════════════
   统计
   ═══════════════════════════════════════ */
.stats-section {
  margin: 0 32rpx 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.stat-divider { width: 1rpx; height: 60rpx; background: #E5E7EB; }

.stat-icon-wrap {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}
.stat-icon-wrap.blue { background: rgba(37,99,235,0.1); }
.stat-icon-wrap.green { background: rgba(16,185,129,0.1); }
.stat-icon-wrap.orange { background: rgba(245,158,11,0.1); }

.stat-value { font-size: 36rpx; font-weight: 800; color: #1F2937; }
.stat-label { font-size: 20rpx; color: #9CA3AF; }

/* ═══════════════════════════════════════
   菜单
   ═══════════════════════════════════════ */
.menu-section {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
}
.menu-item + .menu-item { border-top: 1rpx solid #F3F4F6; }
.menu-item:active { background: #F9FAFB; }

.menu-icon-wrap {
  width: 40rpx; height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-text { flex: 1; font-size: 26rpx; color: #1F2937; }
.menu-arrow { font-size: 32rpx; color: #D1D5DB; }

/* ═══════════════════════════════════════
   版本
   ═══════════════════════════════════════ */
.version-section {
  text-align: center;
  padding: 40rpx 32rpx;
}
.version-section text { font-size: 22rpx; color: #D1D5DB; }

/* ═══════════════════════════════════════
   CSS图标
   ═══════════════════════════════════════ */
.css-icon.avatar-person {
  width: 32rpx; height: 16rpx;
  border: 3rpx solid #2563EB;
  border-top: none;
  border-radius: 0 0 16rpx 16rpx;
  margin-top: 16rpx;
}
.css-icon.avatar-person::before {
  content: '';
  position: absolute;
  top: -22rpx; left: 50%;
  transform: translateX(-50%);
  width: 18rpx; height: 18rpx;
  border: 3rpx solid #2563EB;
  border-radius: 50%;
}

.css-icon.stat-photo {
  width: 20rpx; height: 16rpx;
  border: 3rpx solid #2563EB;
  border-radius: 3rpx;
}
.css-icon.stat-download {
  width: 0; height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 14rpx solid #10B981;
}
.css-icon.stat-star {
  position: relative;
}
.css-icon.stat-star::before {
  content: '★';
  font-size: 28rpx;
  color: #F59E0B;
}

.css-icon.menu-history {
  width: 20rpx; height: 16rpx;
  border: 3rpx solid #6B7280;
  border-radius: 3rpx;
}
.css-icon.menu-privacy {
  width: 20rpx; height: 20rpx;
  border: 3rpx solid #6B7280;
  border-radius: 50%;
}
.css-icon.menu-privacy::before {
  content: '!';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  font-size: 20rpx;
  font-weight: 700;
  color: #6B7280;
}
.css-icon.menu-feedback {
  width: 20rpx; height: 16rpx;
  border: 3rpx solid #6B7280;
  border-radius: 3rpx 3rpx 0 3rpx;
}
.css-icon.menu-feedback::before {
  content: '';
  position: absolute;
  bottom: -6rpx; right: -2rpx;
  width: 6rpx; height: 6rpx;
  border: 2rpx solid #6B7280;
  border-top: none;
  border-right: none;
  transform: rotate(-45deg);
}

/* ═══════════════════════════════════════
   动画
   ═══════════════════════════════════════ */
@keyframes fadeIn { from { opacity:0; transform:translateY(20rpx); } to { opacity:1; transform:translateY(0); } }
@keyframes fadeInUp { from { opacity:0; transform:translateY(30rpx); } to { opacity:1; transform:translateY(0); } }
.fade-in { animation: fadeIn 0.4s ease forwards; }
.fade-in-up { animation: fadeInUp 0.5s ease forwards; }
