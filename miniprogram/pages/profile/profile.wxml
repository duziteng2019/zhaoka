<!--pages/profile/profile.wxml-->
<view class="profile-container">

  <!-- 页面头部 -->
  <view class="page-header fade-in">
    <view class="header-title">个人中心</view>
  </view>

  <!-- 用户卡片 -->
  <view class="user-card fade-in-up">
    <view class="user-avatar">
      <image src="{{userInfo.avatarUrl || ''}}" mode="aspectFill" wx:if="{{userInfo.avatarUrl}}"></image>
      <view class="avatar-placeholder" wx:else>
        <view class="css-icon avatar-person"></view>
      </view>
    </view>
    <view class="user-body">
      <text class="user-name">{{userInfo.nickName || '未登录'}}</text>
      <text class="user-desc">{{userInfo.openid ? '已微信授权' : '登录后可使用云端保存功能'}}</text>
    </view>
    <button wx:if="{{!userInfo.openid}}" class="btn btn-secondary btn-small" bindtap="login">微信登录</button>
  </view>

  <!-- 统计 -->
  <view class="stats-section fade-in-up">
    <view class="stat-item">
      <view class="stat-icon-wrap blue">
        <view class="css-icon stat-photo"></view>
      </view>
      <text class="stat-value">{{totalHistory || 0}}</text>
      <text class="stat-label">制作次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-icon-wrap green">
        <view class="css-icon stat-download"></view>
      </view>
      <text class="stat-value">{{totalDownloads || 0}}</text>
      <text class="stat-label">下载次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-icon-wrap orange">
        <view class="css-icon stat-star"></view>
      </view>
      <text class="stat-value">{{totalOrders || 0}}</text>
      <text class="stat-label">付费次数</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-section fade-in-up">
    <view class="menu-item" bindtap="goToHistory">
      <view class="menu-icon-wrap"><view class="css-icon menu-history"></view></view>
      <text class="menu-text">历史记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToPrivacy">
      <view class="menu-icon-wrap"><view class="css-icon menu-privacy"></view></view>
      <text class="menu-text">隐私政策</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToFeedback">
      <view class="menu-icon-wrap"><view class="css-icon menu-feedback"></view></view>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本 -->
  <view class="version-section">
    <text>版本 {{version || '1.0.0'}}</text>
  </view>
</view>
