/* history.wxss - 历史页 | 瀑布流卡片 */

page {
  background: #F5F7FA;
  min-height: 100vh;
}

.history-container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ═══════════════════════════════════════
   页面头部
   ═══════════════════════════════════════ */
.page-header {
  padding: 32rpx 32rpx 20rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}
.header-count {
  font-size: 22rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  padding: 4rpx 16rpx;
  border-radius: 999px;
}

/* ═══════════════════════════════════════
   瀑布流
   ═══════════════════════════════════════ */
.waterfall {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
}
.waterfall-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 卡片 */
.history-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.history-card:active { transform: scale(0.97); }

.card-thumb {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  background: #E5E7EB;
  overflow: hidden;
}
.card-thumb image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-badge {
  position: absolute;
  top: 12rpx; left: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
  border-radius: 999px;
}
.card-badge.free { background: rgba(156,163,175,0.85); color: #fff; }
.card-badge.paid { background: rgba(16,185,129,0.9); color: #fff; }

.card-body {
  padding: 16rpx;
}
.card-spec {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  margin-bottom: 8rpx;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.meta-color {
  width: 16rpx; height: 16rpx;
  border-radius: 4rpx;
  border: 1rpx solid #E5E7EB;
  flex-shrink: 0;
}
.meta-date {
  font-size: 20rpx;
  color: #9CA3AF;
}

/* ═══════════════════════════════════════
   加载状态
   ═══════════════════════════════════════ */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}
.load-spin {
  width: 24rpx; height: 24rpx;
  border: 3rpx solid #E5E7EB;
  border-top-color: #2563EB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.load-end { color: #D1D5DB; letter-spacing: 2rpx; }

/* ═══════════════════════════════════════
   空状态
   ═══════════════════════════════════════ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx 0;
}
.empty-illustration {
  position: relative;
  width: 200rpx; height: 200rpx;
  margin-bottom: 32rpx;
}
.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #6B7280;
  margin-bottom: 8rpx;
}
.empty-hint {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 32rpx;
}

/* CSS空状态图标 */
.css-icon.empty-box {
  position: absolute;
  top: 20rpx; left: 30rpx;
  width: 120rpx; height: 100rpx;
  border: 4rpx solid #D1D5DB;
  border-radius: 16rpx;
  background: #F9FAFB;
}
.css-icon.empty-box::before {
  content: '';
  position: absolute;
  top: -12rpx; left: 50%;
  transform: translateX(-50%);
  width: 40rpx; height: 8rpx;
  background: #D1D5DB;
  border-radius: 4rpx;
}
.css-icon.empty-question {
  position: absolute;
  bottom: 40rpx; right: 20rpx;
  font-size: 64rpx;
  color: #E5E7EB;
  font-weight: 700;
}
.css-icon.empty-question::before {
  content: '?';
  position: absolute;
  top: 0; left: 0;
}

/* ═══════════════════════════════════════
   动画
   ═══════════════════════════════════════ */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-in-up {
  opacity: 0;
  animation: fadeInUp 0.4s ease forwards;
}
.fade-in { animation: fadeIn 0.4s ease forwards; }
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
