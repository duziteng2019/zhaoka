/* login.wxss - 登录页面 | 赛博朋克科技感设计 */

/* ============================================
   页面容器
   ============================================ */
page {
  background: linear-gradient(135deg, #0A0E27 0%, #1A1F3A 50%, #151A35 100%);
  min-height: 100vh;
}

.login-container {
  min-height: 100vh;
  padding: 60rpx 40rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* ============================================
   动态背景装饰
   ============================================ */
.bg-decoration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 0;
}

.bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.3;
}

.bg-orb-1 {
  width: 400rpx;
  height: 400rpx;
  background: var(--accent-cyan);
  top: -100rpx;
  right: -100rpx;
  animation: floatOrb 8s ease-in-out infinite;
}

.bg-orb-2 {
  width: 300rpx;
  height: 300rpx;
  background: var(--accent-pink);
  bottom: -50rpx;
  left: -50rpx;
  animation: floatOrb 10s ease-in-out infinite reverse;
}

.bg-orb-3 {
  width: 200rpx;
  height: 200rpx;
  background: var(--accent-purple);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: pulseOrb 4s ease-in-out infinite;
}

@keyframes floatOrb {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-40rpx) scale(1.1); }
}

@keyframes pulseOrb {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.2; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.4; }
}

/* ============================================
   登录卡片 - 玻璃态效果
   ============================================ */
.login-card {
  background: rgba(26, 31, 58, 0.7);
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(0, 240, 255, 0.3);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  z-index: 1;
  margin-bottom: 60rpx;
}

/* 扫描线动画 */
.login-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-pink), var(--accent-cyan));
  animation: scanCard 3s linear infinite;
}

@keyframes scanCard {
  0% { opacity: 0; }
  50% { opacity: 1; }
  100% { opacity: 0; }
}

/* 霓虹光晕 */
.login-card::after {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  right: -2rpx;
  bottom: -2rpx;
  background: linear-gradient(45deg, 
    var(--accent-cyan), 
    var(--accent-pink), 
    var(--accent-cyan));
  border-radius: 26rpx;
  z-index: -1;
  opacity: 0;
  transition: opacity 0.3s ease;
  background-size: 400% 400%;
  animation: gradientMove 4s ease infinite;
}

.login-card:focus-within::after {
  opacity: 0.5;
}

@keyframes gradientMove {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ============================================
   Logo 区域
   ============================================ */
.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  text-transform: uppercase;
  text-shadow: 
    0 0 30rpx rgba(0, 240, 255, 0.5),
    0 0 60rpx rgba(0, 240, 255, 0.3);
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 24rpx;
  color: var(--accent-cyan);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  opacity: 0.9;
}

/* ============================================
   表单输入框
   ============================================ */
.form-group {
  margin-bottom: 40rpx;
  position: relative;
}

.input-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
  text-transform: uppercase;
  margin-bottom: 12rpx;
  display: block;
}

.input-wrapper {
  position: relative;
  overflow: hidden;
}

.input-field {
  width: 100%;
  height: 96rpx;
  background: rgba(10, 14, 39, 0.6);
  border: 2rpx solid rgba(0, 240, 255, 0.2);
  border-radius: 12rpx;
  padding: 0 32rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  letter-spacing: 1rpx;
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.input-field::placeholder {
  color: var(--text-muted);
}

.input-field:focus {
  border-color: var(--accent-cyan);
  box-shadow: 
    0 0 20rpx rgba(0, 240, 255, 0.3),
    inset 0 0 20rpx rgba(0, 240, 255, 0.05);
}

/* 输入框底部线条动画 */
.input-wrapper::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-pink), var(--accent-cyan));
  transform: scaleX(0);
  transition: transform 0.3s ease;
}

.input-wrapper.focus-line::after {
  transform: scaleX(1);
}

/* ============================================
   按钮
   ============================================ */
.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 50rpx;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, var(--accent-cyan), #00B8D4);
  border: none;
  border-radius: 12rpx;
  color: #0A0E27;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  clip-path: polygon(12rpx 0, 100% 0, 100% calc(100% - 12rpx), calc(100% - 12rpx) 100%, 0 100%, 0 12rpx);
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, 
    transparent, 
    rgba(255, 255, 255, 0.3), 
    transparent);
  transition: left 0.5s ease;
}

.login-btn:active::before {
  left: 100%;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 
    0 0 30rpx rgba(0, 240, 255, 0.6),
    0 0 60rpx rgba(0, 240, 255, 0.4);
}

.register-link {
  text-align: center;
  margin-top: 30rpx;
}

.register-link-text {
  font-size: 26rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

.register-link-text .highlight {
  color: var(--accent-cyan);
  text-decoration: none;
  position: relative;
}

.register-link-text .highlight::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, var(--accent-cyan), var(--accent-pink));
  transform: scaleX(0);
  transition: transform 0.3s ease;
}

.register-link-text .highlight:active::after {
  transform: scaleX(1);
}

/* ============================================
   科技装饰
   ============================================ */
.tech-line {
  height: 2rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    var(--accent-cyan) 50%, 
    transparent 100%);
  margin: 40rpx 0;
  position: relative;
}

.tech-line::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  background: var(--accent-cyan);
  border-radius: 50%;
  box-shadow: 0 0 10rpx var(--accent-cyan);
  animation: pulseDot 2s ease-in-out infinite;
}

@keyframes pulseDot {
  0%, 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.5; transform: translate(-50%, -50%) scale(1.5); }
}

/* 角落装饰 */
.login-corner {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid var(--accent-cyan);
  opacity: 0.4;
}

.login-corner::before,
.login-corner::after {
  content: '';
  position: absolute;
  background: var(--accent-cyan);
}

.login-corner::before {
  width: 8rpx;
  height: 2rpx;
}

.login-corner::after {
  width: 2rpx;
  height: 8rpx;
}

.corner-tl { top: 20rpx; left: 20rpx; border-right: none; border-bottom: none; }
.corner-tr { top: 20rpx; right: 20rpx; border-left: none; border-bottom: none; }
.corner-bl { bottom: 20rpx; left: 20rpx; border-right: none; border-top: none; }
.corner-br { bottom: 20rpx; right: 20rpx; border-left: none; border-top: none; }
