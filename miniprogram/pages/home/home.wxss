/* home.wxss - 首页 | 全新视觉 */

page {
  background: #F5F7FA;
  min-height: 100vh;
  overflow-x: hidden;
}

.home-container {
  min-height: 100vh;
}

.bottom-spacer {
  height: 40rpx;
}

/* ═══════════════════════════════════════
   结果视图
   ═══════════════════════════════════════ */
.result-section {
  padding: 32rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
}
.result-actions {
  display: flex;
  gap: 12rpx;
}
.result-action {
  font-size: 24rpx;
  color: #2563EB;
  padding: 6rpx 16rpx;
  border: 2rpx solid #2563EB;
  border-radius: 999px;
}
.result-action:active { background: rgba(37,99,235,0.05); }

/* 处理中动画 */
.result-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 120rpx 0;
}
.load-spinner {
  width: 64rpx; height: 64rpx;
  border: 6rpx solid #E5E7EB;
  border-top-color: #2563EB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.result-loading text {
  font-size: 26rpx;
  color: #6B7280;
}

/* 结果预览 */
.result-preview {
  position: relative;
  width: 100%;
  aspect-ratio: 3/4;
  background: #E5E7EB;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.result-image {
  width: 100%; height: 100%;
  object-fit: contain;
}
.result-badge {
  position: absolute;
  bottom: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: #fff;
  background: rgba(0,0,0,0.5);
  padding: 4rpx 16rpx;
  border-radius: 999px;
}

/* 颜色选择 */
.result-colors {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-bottom: 24rpx;
}
.color-swatch {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.color-swatch.active { border-color: #2563EB; background: rgba(37,99,235,0.04); }
.swatch {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #E5E7EB;
}
.swatch.white { background: #fff; }
.swatch.blue { background: #4A90E2; }
.swatch.red { background: #E74C3C; }
.color-swatch text { font-size: 22rpx; color: #6B7280; }

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ═══════════════════════════════════════
   Hero 渐变区
   ═══════════════════════════════════════ */
.hero-section {
  position: relative;
  overflow: hidden;
  padding: 48rpx 40rpx 56rpx;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 50%, #1E40AF 100%);
  border-radius: 0 0 48rpx 48rpx;
  margin-bottom: 32rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(4px);
  padding: 6rpx 20rpx;
  border-radius: 999px;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
  margin-bottom: 32rpx;
}

/* 步骤点 */
.hero-steps {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 8rpx;
}
.step-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
}
.step-dot.active { background: #fff; width: 20rpx; height: 20rpx; }
.step-line {
  flex: 1;
  height: 2rpx;
  background: rgba(255,255,255,0.3);
}
.step-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 36rpx;
}
.step-labels text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* Hero按钮 */
.btn-hero {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  padding: 24rpx 0;
  background: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #2563EB;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}
.btn-hero:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.btn-arrow {
  font-size: 36rpx;
  transition: transform 0.2s;
}
.btn-hero:active .btn-arrow {
  transform: translateX(8rpx);
}

/* 装饰圆 */
.hero-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
  background: #fff;
  z-index: 1;
}
.c1 { width: 400rpx; height: 400rpx; top: -120rpx; right: -80rpx; }
.c2 { width: 200rpx; height: 200rpx; bottom: -40rpx; left: -60rpx; }
.c3 { width: 120rpx; height: 120rpx; top: 60rpx; right: 40rpx; opacity: 0.05; }

/* ═══════════════════════════════════════
   通用区块
   ═══════════════════════════════════════ */
.specs-section, .features-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
}

.section-count {
  font-size: 22rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  padding: 4rpx 16rpx;
  border-radius: 999px;
}

/* ═══════════════════════════════════════
   规格卡片 - 2x2网格
   ═══════════════════════════════════════ */
.specs-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.spec-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.spec-card:active {
  transform: scale(0.97);
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.06);
}

/* 规格图标 - 4色循环 */
.spec-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.spec-icon.color-0 { background: linear-gradient(135deg, #2563EB, #3B82F6); }
.spec-icon.color-1 { background: linear-gradient(135deg, #10B981, #34D399); }
.spec-icon.color-2 { background: linear-gradient(135deg, #F59E0B, #FBBF24); }
.spec-icon.color-3 { background: linear-gradient(135deg, #EF4444, #F87171); }

.spec-info { display: flex; flex-direction: column; gap: 4rpx; }
.spec-name { font-size: 28rpx; font-weight: 600; color: #1F2937; }
.spec-desc { font-size: 22rpx; color: #9CA3AF; }

/* ═══════════════════════════════════════
   骨架屏
   ═══════════════════════════════════════ */
.spec-card.skeleton { pointer-events: none; }
.skeleton-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 14rpx;
  background: linear-gradient(90deg, #E5E7EB 25%, #F3F4F6 50%, #E5E7EB 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  flex-shrink: 0;
}
.skeleton-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.skeleton-line {
  height: 24rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #E5E7EB 25%, #F3F4F6 50%, #E5E7EB 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.skeleton-line.w-60 { width: 60%; }
.skeleton-line.w-40 { width: 40%; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ═══════════════════════════════════════
   服务特色 - CSS图标
   ═══════════════════════════════════════ */
.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.feature-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.feature-icon-wrap {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}
.feature-icon-wrap.primary { background: rgba(37,99,235,0.1); }
.feature-icon-wrap.accent { background: rgba(245,158,11,0.1); }
.feature-icon-wrap.success { background: rgba(16,185,129,0.1); }
.feature-icon-wrap.warning { background: rgba(239,68,68,0.1); }

.feature-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4rpx;
}
.feature-desc {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ═══════════════════════════════════════
   CSS图标 - 纯几何
   ═══════════════════════════════════════ */
.css-icon {
  position: relative;
}
/* 人像图标 */
.css-icon.person {
  width: 28rpx; height: 14rpx;
  border: 3rpx solid #2563EB;
  border-top: none;
  border-radius: 0 0 14rpx 14rpx;
  margin-top: 14rpx;
}
.css-icon.person::before {
  content: '';
  position: absolute;
  top: -24rpx; left: 50%;
  transform: translateX(-50%);
  width: 18rpx; height: 18rpx;
  border: 3rpx solid #2563EB;
  border-radius: 50%;
}
.feature-icon-wrap.accent .css-icon.palette {
  width: 24rpx; height: 24rpx;
  border: 3rpx solid #F59E0B;
  border-radius: 50%;
}
.feature-icon-wrap.accent .css-icon.palette::before {
  content: '';
  position: absolute;
  top: 2rpx; left: 2rpx;
  width: 16rpx; height: 16rpx;
  background: #F59E0B;
  border-radius: 50%;
  opacity: 0.3;
}
/* 下载图标 */
.css-icon.download {
  width: 0; height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 18rpx solid #10B981;
  margin-top: 6rpx;
}
.css-icon.download::before {
  content: '';
  position: absolute;
  bottom: 14rpx; left: 50%;
  transform: translateX(-50%);
  width: 3rpx; height: 20rpx;
  background: #10B981;
}
/* 时钟图标 */
.css-icon.clock {
  width: 24rpx; height: 24rpx;
  border: 3rpx solid #EF4444;
  border-radius: 50%;
}
.css-icon.clock::before {
  content: '';
  position: absolute;
  top: 2rpx; left: 50%;
  transform: translateX(-50%);
  width: 3rpx; height: 10rpx;
  background: #EF4444;
  border-radius: 2rpx;
}
.css-icon.clock::after {
  content: '';
  position: absolute;
  top: 8rpx; left: 10rpx;
  width: 6rpx; height: 3rpx;
  background: #EF4444;
  border-radius: 2rpx;
}
