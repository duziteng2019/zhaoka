<!--pages/home/home.wxml-->
<view class="home-container page-container">

  <!-- Hero区域 - 渐变背景 -->
  <view class="hero-section">
    <view class="hero-content">
      <view class="hero-badge">🤖 AI智能制作</view>
      <view class="hero-title">三步完成<br/>专业证件照</view>
      <view class="hero-steps">
        <view class="step-dot active"></view>
        <view class="step-line"></view>
        <view class="step-dot"></view>
        <view class="step-line"></view>
        <view class="step-dot"></view>
      </view>
      <view class="step-labels">
        <text>选规格</text>
        <text>上传照</text>
        <text>导出</text>
      </view>
      <button class="btn-hero" bindtap="startCreate">
        <text>立即制作</text>
        <view class="btn-arrow">→</view>
      </button>
    </view>
    <!-- 装饰圆 -->
    <view class="hero-circle c1"></view>
    <view class="hero-circle c2"></view>
    <view class="hero-circle c3"></view>
  </view>

  <!-- 常用规格 -->
  <view class="specs-section">
    <view class="section-header">
      <view class="section-title">常用规格</view>
      <text class="section-count" wx:if="{{!loadingSpecs}}">{{specs.length}}种</text>
    </view>

    <!-- 骨架屏 -->
    <view class="specs-grid" wx:if="{{loadingSpecs}}">
      <view class="spec-card skeleton" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-icon"></view>
        <view class="skeleton-text">
          <view class="skeleton-line w-60"></view>
          <view class="skeleton-line w-40"></view>
        </view>
      </view>
    </view>

    <!-- 规格列表 -->
    <view class="specs-grid" wx:else>
      <view class="spec-card" wx:for="{{specs}}" wx:key="id" bindtap="selectSpec" data-spec="{{item.id}}">
        <view class="spec-icon {{'color-' + (index % 4)}}">{{item.name.slice(0,1)}}</view>
        <view class="spec-info">
          <text class="spec-name">{{item.name}}</text>
          <text class="spec-desc">{{item.size || item.desc || ''}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务特色 -->
  <view class="features-section">
    <view class="section-header">
      <view class="section-title">服务特色</view>
    </view>
    <view class="features-grid">
      <view class="feature-item">
        <view class="feature-icon-wrap primary">
          <view class="css-icon person"></view>
        </view>
        <view class="feature-title">智能抠图</view>
        <view class="feature-desc">AI精准识别人像</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon-wrap accent">
          <view class="css-icon palette"></view>
        </view>
        <view class="feature-title">多色背景</view>
        <view class="feature-desc">白/蓝/红自由切换</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon-wrap success">
          <view class="css-icon download"></view>
        </view>
        <view class="feature-title">高清导出</view>
        <view class="feature-desc">支持冲印级分辨率</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon-wrap warning">
          <view class="css-icon clock"></view>
        </view>
        <view class="feature-title">历史记录</view>
        <view class="feature-desc">随时查看和下载</view>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer"></view>
</view>
