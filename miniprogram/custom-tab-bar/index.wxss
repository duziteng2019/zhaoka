/* custom-tab-bar/index.wxss - 自定义TabBar | 简约专业风格 */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 112rpx;
  background: #FFFFFF;
  display: flex;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1000;
  border-top: 1rpx solid #E5E7EB;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  position: relative;
  transition: all 0.2s ease;
}

.tab-bar-item:active {
  transform: scale(0.95);
}

/* Tab 图标容器 */
.tab-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  margin-bottom: 4rpx;
}

.tab-icon image {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.6;
  transition: all 0.2s ease;
}

/* 选中状态 */
.tab-bar-item.active .tab-icon image {
  opacity: 1;
}

.tab-bar-item.active .tab-icon {
  transform: translateY(-2rpx);
}

/* 选中指示器 */
.tab-bar-item.active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #2563EB;
  border-radius: 0 0 4rpx 4rpx;
}

/* Tab 文字 */
.tab-text {
  font-size: 22rpx;
  color: #9CA3AF;
  font-weight: 500;
  transition: all 0.2s ease;
}

.tab-bar-item.active .tab-text {
  color: #2563EB;
  font-weight: 600;
}

/* 安全区域适配 */
.tab-bar-safe-area {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  width: 100%;
  background: #FFFFFF;
  position: absolute;
  bottom: 0;
  left: 0;
}
