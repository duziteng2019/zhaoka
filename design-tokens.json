        },
        "forwards": {
          "value": "forwards",
          "type": "easing",
          "description": "保持结束状态"
        },
        "infinite": {
          "value": "infinite",
          "type": "easing",
          "description": "无限循环"
        },
        "linear": {
          "value": "linear",
          "type": "easing",
          "description": "线性动画"
        }
      },
      "keyframes": {
        "fadeIn": {
          "type": "keyframes",
          "description": "淡入动画",
          "from": { "opacity": "0", "transform": "translateY(30rpx)" },
          "to": { "opacity": "1", "transform": "translateY(0)" }
        },
        "slideInLeft": {
          "type": "keyframes",
          "description": "从左侧滑入",
          "from": { "opacity": "0", "transform": "translateX(-50rpx)" },
          "to": { "opacity": "1", "transform": "translateX(0)" }
        },
        "slideInRight": {
          "type": "keyframes",
          "description": "从右侧滑入",
          "from": { "opacity": "0", "transform": "translateX(50rpx)" },
          "to": { "opacity": "1", "transform": "translateX(0)" }
        },
        "pulse": {
          "type": "keyframes",
          "description": "脉冲动画",
          "0%, 100%": { "opacity": "1" },
          "50%": { "opacity": "0.5" }
        },
        "shimmer": {
          "type": "keyframes",
          "description": "闪烁动画",
          "0%": { "transform": "translateX(-100%)" },
          "100%": { "transform": "translateX(200%)" }
        },
        "scanline": {
          "type": "keyframes",
          "description": "扫描线动画",
          "0%": { "background-position": "0 0" },
          "100%": { "background-position": "0 100rpx" }
        },
        "glowPulse": {
          "type": "keyframes",
          "description": "发光脉冲",
          "0%, 100%": { "box-shadow": "0 0 10rpx var(--shadow-glow)" },
          "50%": { "box-shadow": "0 0 30rpx var(--shadow-glow), 0 0 50rpx rgba(0, 240, 255, 0.3)" }
        }
      }
